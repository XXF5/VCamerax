<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_clone_setup"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    tools:context=".ui.clone.CloneSetupActivity">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_clone"
        style="@style/Widget.DualSpaceOBS.Toolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/toolbar_height"
        app:title="@string/clone_wizard_title"
        app:navigationIcon="@drawable/ic_back"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Progress bar -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progress_clone"
        style="@style/Widget.DualSpaceOBS.LinearProgressIndicator"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:progress="20"
        app:layout_constraintTop_toBottomOf="@id/toolbar_clone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Step Indicator (5 dots) -->
    <LinearLayout
        android:id="@+id/layout_step_indicator"
        style="@style/StepIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/margin_large"
        app:layout_constraintTop_toBottomOf="@id/progress_clone"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View
            android:id="@+id/step_dot_1"
            style="@style/StepIndicator.Dot.Active" />

        <View
            android:layout_width="@dimen/step_dot_gap"
            android:layout_height="@dimen/step_dot_size"
            android:layout_gravity="center_vertical" />

        <View
            android:id="@+id/step_dot_2"
            style="@style/StepIndicator.Dot.Inactive" />

        <View
            android:layout_width="@dimen/step_dot_gap"
            android:layout_height="@dimen/step_dot_size"
            android:layout_gravity="center_vertical" />

        <View
            android:id="@+id/step_dot_3"
            style="@style/StepIndicator.Dot.Inactive" />

        <View
            android:layout_width="@dimen/step_dot_gap"
            android:layout_height="@dimen/step_dot_size"
            android:layout_gravity="center_vertical" />

        <View
            android:id="@+id/step_dot_4"
            style="@style/StepIndicator.Dot.Inactive" />

        <View
            android:layout_width="@dimen/step_dot_gap"
            android:layout_height="@dimen/step_dot_size"
            android:layout_gravity="center_vertical" />

        <View
            android:id="@+id/step_dot_5"
            style="@style/StepIndicator.Dot.Inactive" />

    </LinearLayout>

    <!-- Step title -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tv_step_title"
        style="@style/TextAppearance.DualSpaceOBS.TitleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/margin_medium"
        android:text="@string/clone_step_select"
        app:layout_constraintTop_toBottomOf="@id/layout_step_indicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ViewPager2 for wizard steps -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager_clone_steps"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/margin_medium"
        android:layout_marginBottom="@dimen/margin_medium"
        app:layout_constraintTop_toBottomOf="@id/tv_step_title"
        app:layout_constraintBottom_toTopOf="@id/layout_action_buttons"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Action Buttons -->
    <LinearLayout
        android:id="@+id/layout_action_buttons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/padding_standard"
        android:paddingVertical="@dimen/padding_medium"
        android:background="@color/background_surface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Previous / Cancel -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_previous"
            style="@style/Widget.DualSpaceOBS.Button.Text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_previous"
            android:visibility="invisible" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <!-- Next / Clone -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next"
            style="@style/Widget.DualSpaceOBS.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_next" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
